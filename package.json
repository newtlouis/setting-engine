{
    "name": "instagram-lead-engine-root",
    "version": "1.0.0",
    "description": "Root workspace for Instagram Lead Engine",
    "private": true,
    "type": "module",
    "workspaces": [
        "agents/collector",
        "agents/outreach",
        "agents/dmresponder"
    ],
    "scripts": {
        "ui": "cd agents/collector && npm run ui --",
        "scrape": "cd agents/collector && npm run scrape --",
        "postscrape": "npm run backup:remote",
        "collect": "cd agents/collector && npm run collect --",
        "postcollect": "npm run backup:remote",
        "send": "cd agents/outreach && npm run send --",
        "postsend": "npm run backup:remote",
        "reply": "cd agents/dmresponder && npm run reply --",
        "reply:conversation": "cd agents/dmresponder && npm run cron -- --show-browser --conversation-only",
        "postreply": "npm run backup:remote",
        "reply:auto": "cd agents/dmresponder && npm run cron -- --show-browser",
        "postreply:auto": "npm run backup:remote",
        "db:admin": "python3 -m sqlite_web ./agents/collector/permanent-data/leads.db --port 8081 --no-browser",
        "backup": "node agents/collector/scripts/backup.js",
        "backup:remote": "npm run backup -- --upload",
        "restore": "node agents/collector/scripts/restore.js",
        "restore:remote": "node agents/collector/scripts/restore.js --remote"
    },
    "author": "Louis",
    "license": "ISC",
    "dependencies": {
        "better-sqlite3": "^12.5.0",
        "express": "^5.2.1"
    }
}