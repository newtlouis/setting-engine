{
    "name": "instagram-lead-engine-root",
    "version": "1.0.0",
    "description": "Root workspace for Instagram Lead Engine",
    "private": true,
    "type": "module",
    "workspaces": [
        "agents/collector",
        "agents/outreach",
        "agents/dmresponder",
        "agents/prospector"
    ],
    "scripts": {
        "test": "node --test tests/*.test.js",
        "ui": "npx tauri dev",
        "ui:web": "cd agents/collector && npm run ui --",
        "scrape": "cd agents/collector && npm run scrape --",
        "postscrape": "npm run backup:remote",
        "collect": "cd agents/collector && npm run collect --",
        "postcollect": "npm run backup:remote",
        "send": "cd agents/outreach && npm run send --",
        "postsend": "npm run backup:remote",
        "prospect": "cd agents/prospector && npm run prospect --",
        "postprospect": "npm run backup:remote",
        "reply": "cd agents/dmresponder && npm run reply --",
        "reply:conversation": "cd agents/dmresponder && npm run cron -- --show-browser --conversation-only",
        "reply:outreach": "cd agents/dmresponder && npm run cron -- --show-browser --outreach-only",
        "postreply": "npm run backup:remote",
        "reply:auto": "cd agents/dmresponder && npm run cron -- --show-browser",
        "reply:followup": "cd agents/dmresponder && npm run followup --",
        "postreply:auto": "npm run backup:remote",
        "respond:inbox": "cd agents/dmresponder && npm run inbox --",
        "respond:followers": "cd agents/dmresponder && npm run followers --",
        "respond:engagement": "cd agents/dmresponder && npm run engagement --",
        "postrespond:inbox": "npm run backup:remote",
        "harvest": "node scripts/harvest.js",
        "send-queued": "node scripts/send_queued.js",
        "followers": "npm run respond:followers --",
        "engagement": "npm run respond:engagement --",
        "open:session": "node open_session.js",
        "db:admin": "python3 -m sqlite_web ./agents/collector/permanent-data/leads.db --port 8081 --no-browser",
        "backup": "node agents/collector/scripts/backup.js",
        "backup:remote": "npm run backup -- --upload",
        "restore": "node agents/collector/scripts/restore.js",
        "restore:remote": "node agents/collector/scripts/restore.js --remote",
        "analyze:steps": "cd agents/collector && npm run analyze:steps --",
        "test:e2e": "cd agents/dmresponder && npm run test:e2e",
        "dm-sync": "cd agents/dmresponder && npm run cron -- --inbox",
        "broadcast": "cd agents/dmresponder && npm run broadcast --",
        "scrape-followers": "cd agents/dmresponder && npm run scrape-followers --",
        "kpi-daily": "node scripts/kpi-daily.js",
        "hourly-cycle": "node scripts/hourly-cycle.js",
        "export-outreach-sheet": "node scripts/export_outreach_sheet.js",
        "import-outreach-sheet": "node scripts/import_outreach_sheet.js"
    },
    "author": "Louis",
    "license": "ISC",
    "dependencies": {
        "better-sqlite3": "^12.5.0",
        "express": "^5.2.1",
        "googleapis": "^171.4.0"
    },
    "devDependencies": {
        "@tauri-apps/api": "^2.10.1",
        "@tauri-apps/cli": "^2.10.1"
    }
}
