# Database path (shared with collector)
DB_PATH=../collector/permanent-data/leads.db

# Rate limiting (CRITICAL - don't reduce these!)
MIN_DELAY_BETWEEN_DMS=60000   # 1 minute minimum
MAX_DELAY_BETWEEN_DMS=180000  # 3 minutes maximum
MAX_DMS_PER_SESSION=10        # Max DMs before stopping
MAX_DMS_PER_DAY=20            # Daily limit

# Session management
SESSION_COOLDOWN_HOURS=4      # Wait time between sessions

# Browser settings
HEADLESS=false                # Keep false for safety
SLOW_MO=50                    # Slow down actions (ms)

# Timeouts
PAGE_TIMEOUT=30000            # Page load timeout
DM_SEND_TIMEOUT=15000         # DM send timeout

# Lead selection criteria
MIN_ENGAGEMENT_SCORE=0        # Minimum engagement score (0 = include all)
MIN_FOLLOWERS=0               # Minimum follower count (0 = include all)
MAX_FOLLOWERS=1000000         # Maximum follower count
EXCLUDE_PRIVATE=true          # Skip private accounts
EXCLUDE_BUSINESS=false        # Include business accounts
EXCLUDE_VERIFIED=false        # Include verified accounts
