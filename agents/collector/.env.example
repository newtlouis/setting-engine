# Instagram Collector Agent Configuration

# Output directory (relative or absolute path)
OUTPUT_DIR=./output

# Debug mode (set to 'true' for verbose logging)
DEBUG=false

# Browser settings
HEADLESS=false
SLOW_MO=100

# Default limits
DEFAULT_MAX_POSTS=50
DEFAULT_MAX_COMMENTS=100

# Delays (milliseconds)
MIN_DELAY=3000
MAX_DELAY=7000
