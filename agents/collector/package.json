{
  "name": "instagram-collector-agent",
  "version": "1.0.0",
  "description": "Instagram Collector Agent - Discovery and Scraping",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "collector": "./bin/run.js"
  },
  "scripts": {
    "start": "node bin/run.js",
    "scrape": "node collect.js",
    "scrape-core": "node bin/run.js",
    "save-comments": "node append-to-master.js",
    "build-final-db": "node build-final-excel.js",
    "collect": "node collect.js",
    "process": "node collect.js --only-save-build",
    "scrape-profiles": "node scrape-profiles.js",
    "migrate": "node migrate-csv-to-db.js",
    "test": "node --test tests/*.test.js",
    "dev": "node --watch bin/run.js",
    "ui": "node ../dashboard/server.js",
    "db:admin": "python3 -m sqlite_web permanent-data/leads.db --port 8081 --no-browser",
    "dm-sync": "node bin/dm-sync.js",
    "dm-sync:stats": "node bin/dm-sync.js --stats",
    "dm-sync:list": "node bin/dm-sync.js --list",
    "analyze": "node bin/analyze-conversations.js",
    "analyze:list": "node bin/analyze-conversations.js --list",
    "analyze:steps": "node bin/analyze-funnel-steps.js"
  },
  "keywords": [
    "instagram",
    "scraper",
    "lead-generation",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.4.6",
    "commander": "^11.1.0",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "openai": "^6.17.0",
    "playwright": "^1.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
