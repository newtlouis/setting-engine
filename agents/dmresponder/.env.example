# Instagram credentials for automatic login
INSTAGRAM_USERNAME="your_instagram_username"
INSTAGRAM_PASSWORD="your_instagram_password"

# Multi-Account Credentials
# If using --profile <name>, the system looks for:
# INSTAGRAM_USERNAME_<NAME_UPPERCASE>=
# INSTAGRAM_PASSWORD_<NAME_UPPERCASE>=

# The API key for the LLM (e.g., OpenAI)
OPENAI_API_KEY="your_api_key_here"
