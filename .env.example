# ============================================================================
#  Setting Engine — Exemple de configuration (.env)
# ============================================================================
#  Copiez ce fichier en ".env" et remplissez les valeurs.
#  Le script setup.ps1 le copie automatiquement à la racine ET dans
#  agents/collector, agents/outreach et agents/dmresponder.
#
#  ⚠️  NE JAMAIS committer votre vrai .env (il est ignoré par .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
#  IA / LLM  (obligatoire pour la génération de messages)
# ----------------------------------------------------------------------------
# Clé API OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
#  Identifiants Instagram  (OPTIONNEL — sinon login manuel au 1er lancement)
# ----------------------------------------------------------------------------
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# --- Multi-comptes ---
# Avec --profile <nom>, le système cherche les variables suffixées par le
# nom du profil en MAJUSCULES :
#   INSTAGRAM_USERNAME_<NOM>=...
#   INSTAGRAM_PASSWORD_<NOM>=...
# Exemple pour --profile melanie :
# INSTAGRAM_USERNAME_MELANIE=
# INSTAGRAM_PASSWORD_MELANIE=
# INSTAGRAM_USERNAME_HERCULE=
# INSTAGRAM_PASSWORD_HERCULE=
# INSTAGRAM_USERNAME_BUSINESS=
# INSTAGRAM_PASSWORD_BUSINESS=
# INSTAGRAM_USERNAME_MY_ACCOUNT=
# INSTAGRAM_PASSWORD_MY_ACCOUNT=

# Profil par défaut utilisé si --profile n'est pas précisé
IG_PROFILE=anonymous

# ----------------------------------------------------------------------------
#  Base de données & sorties
# ----------------------------------------------------------------------------
# Chemin de la base SQLite partagée (laisser vide = défaut du projet)
# DB_PATH=agents/collector/permanent-data/leads.db
OUTPUT_DIR=./output

# Port du dashboard web (npm run ui:web)
PORT=3000

# ----------------------------------------------------------------------------
#  Navigateur (Playwright)
# ----------------------------------------------------------------------------
HEADLESS=false          # Garder false pour la sécurité (navigateur visible)
SLOW_MO=100             # Ralentit les actions (ms) pour un comportement humain
PAGE_TIMEOUT=30000      # Timeout de chargement de page (ms)
DM_SEND_TIMEOUT=15000   # Timeout d'envoi de DM (ms)
DEBUG=false             # true = logs verbeux

# ----------------------------------------------------------------------------
#  Limites d'envoi de DM  (CRITIQUE — ne pas réduire les délais !)
# ----------------------------------------------------------------------------
MIN_DELAY_BETWEEN_DMS=60000    # 1 min minimum entre 2 DMs
MAX_DELAY_BETWEEN_DMS=180000   # 3 min maximum entre 2 DMs
MAX_DMS_PER_SESSION=10         # DMs max avant arrêt d'une session
MAX_DMS_PER_DAY=20             # Limite quotidienne
SESSION_COOLDOWN_HOURS=4       # Temps d'attente entre 2 sessions

# ----------------------------------------------------------------------------
#  Sélection / qualification des leads
# ----------------------------------------------------------------------------
MIN_ENGAGEMENT_SCORE=0   # Score d'engagement minimum (0 = tout inclure)
QUALIFICATION_ENABLED=true
EXCLUDE_BUSINESS=false   # true = ignorer les comptes business
EXCLUDE_VERIFIED=false   # true = ignorer les comptes certifiés

# ----------------------------------------------------------------------------
#  Calendly  (OPTIONNEL — prise de rendez-vous)
# ----------------------------------------------------------------------------
CALENDLY_TOKEN=
CALENDLY_EVENT_TYPE=
CALENDLY_TEST_EMAIL=
CALENDLY_TEST_PROFILE=default

# ----------------------------------------------------------------------------
#  Google (OPTIONNEL — export Sheets / service account)
# ----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
