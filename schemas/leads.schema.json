{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://instagram-lead-engine.com/schemas/leads.json",
  "title": "Leads",
  "description": "Schema for qualified leads generated by Prospector Agent",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "username",
      "profile_url",
      "warmth",
      "score",
      "reasoning",
      "pain_points",
      "goals"
    ],
    "properties": {
      "username": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9._]+$",
        "description": "Instagram username (without @)"
      },
      "profile_url": {
        "type": "string",
        "format": "uri",
        "pattern": "^https://www\\.instagram\\.com/[^/]+/?$",
        "description": "URL to profile"
      },
      "warmth": {
        "type": "string",
        "enum": ["warm", "cold", "irrelevant"],
        "description": "Lead classification"
      },
      "score": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "description": "Lead quality score (0-100)"
      },
      "reasoning": {
        "type": "string",
        "description": "Explanation for the classification"
      },
      "pain_points": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Identified pain points from comment"
      },
      "goals": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Identified goals or desires"
      },
      "comment_text": {
        "type": "string",
        "description": "Original comment text"
      },
      "post_url": {
        "type": "string",
        "format": "uri",
        "description": "URL of post where comment was made"
      },
      "objections_likely": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Predicted objections"
      },
      "best_approach": {
        "type": "string",
        "description": "Recommended outreach strategy"
      }
    }
  }
}
