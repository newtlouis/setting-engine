{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://instagram-lead-engine.com/schemas/messages.json",
  "title": "Messages",
  "description": "Schema for personalized outreach messages generated by Lead Analyzer Agent",
  "type": "object",
  "required": ["persona_summary", "top_prospects"],
  "properties": {
    "persona_summary": {
      "type": "object",
      "required": [
        "common_pain_points",
        "common_goals",
        "demographic_insights",
        "best_hooks"
      ],
      "properties": {
        "common_pain_points": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Most common pain points across all leads"
        },
        "common_goals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Most common goals across all leads"
        },
        "demographic_insights": {
          "type": "string",
          "description": "Summary of demographic patterns"
        },
        "best_hooks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Recommended hooks for content"
        }
      }
    },
    "top_prospects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["username", "profile_url", "score", "warmth", "messages"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Instagram username"
          },
          "profile_url": {
            "type": "string",
            "format": "uri",
            "description": "Profile URL"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Lead score"
          },
          "warmth": {
            "type": "string",
            "enum": ["warm", "cold", "irrelevant"],
            "description": "Lead classification"
          },
          "why_top_prospect": {
            "type": "string",
            "description": "Reason for being top prospect"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["angle", "script", "purpose"],
              "properties": {
                "angle": {
                  "type": "string",
                  "description": "Message approach/angle"
                },
                "script": {
                  "type": "string",
                  "description": "Suggested message text"
                },
                "purpose": {
                  "type": "string",
                  "enum": ["rapport", "pain_point", "cta", "qualification"],
                  "description": "Purpose of this message"
                }
              }
            },
            "minItems": 1,
            "maxItems": 5,
            "description": "Sequence of suggested messages"
          }
        }
      },
      "description": "Top 3-5 prospects with personalized message sequences"
    }
  }
}
